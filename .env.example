# Networking
BACKEND_HOST=0.0.0.0
BACKEND_PORT=6150
FRONTEND_HOST=0.0.0.0
FRONTEND_PORT=6151

# Public URLs
PUBLIC_API_BASE_URL=http://localhost:6150/api/v1
PUBLIC_FRONTEND_ORIGIN=http://localhost:6151

# Backend allow-lists
DJANGO_DEBUG=true
DJANGO_SECRET_KEY=replace-this-with-a-long-random-value
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1,100.72.232.210,0.0.0.0
DJANGO_CORS_ALLOWED_ORIGINS=http://localhost:6151,http://127.0.0.1:6151,http://0.0.0.0:6151,tauri://localhost,http://tauri.localhost,https://tauri.localhost,app://local
DJANGO_SERVE_STORAGE_FILES=false
DJANGO_SECURE_SSL_REDIRECT=false
DJANGO_SECURE_HSTS_SECONDS=0
DJANGO_SECURE_HSTS_INCLUDE_SUBDOMAINS=false
DJANGO_SECURE_HSTS_PRELOAD=false
DJANGO_SESSION_COOKIE_SECURE=false
DJANGO_CSRF_COOKIE_SECURE=false

# Scheduler / agent defaults
SCHEDULER_API_BASE_URL=http://localhost:6150/api/v1
AGENT_PORT=6152
# Address that backend/scheduler uses to call this agent.
AGENT_IP=127.0.0.1
AGENT_NODE_NAME=local-agent
# Physical GPU count reported by this agent.
AGENT_GPU_TOTAL=1
# Logical training slots exposed to the scheduler. Defaults to AGENT_GPU_TOTAL.
# For H20 single-GPU overcommit, set AGENT_GPU_SLOT_TOTAL=4 for 4/4 slots on GPU 0.
AGENT_GPU_SLOT_TOTAL=1
# Address that browsers use to upload datasets directly to this agent.
# Set this to a public IP/domain or a tunnel URL, without a trailing slash.
AGENT_PUBLIC_BASE_URL=http://localhost:6152
AGENT_UPLOAD_ENABLED=true
AGENT_UPLOAD_ALLOWED_ORIGINS=http://localhost:6151,http://127.0.0.1:6151
AGENT_DATASET_DIR=backend/storage/datasets_cache
DATASET_UPLOAD_SESSION_TIMEOUT_SECONDS=7200
DATASET_UPLOAD_CHUNK_SIZE=8388608

# Auth Configuration
# In development mode, use this fixed code instead of sending real SMS
# Set to empty string in production to use real SMS
AUTH_DEV_CODE=000000
# Comma-separated phone numbers that bypass one-mobile/one-desktop login limits.
AUTH_SINGLE_DEVICE_BYPASS_PHONES=
# Comma-separated phone numbers that should default to Plus permissions.
AUTH_PLUS_WHITELIST_PHONES=
# Comma-separated phone numbers that bypass account resource count limits.
AUTH_NO_LIMITS_WHITELIST_PHONES=18707151525

# Django Admin (defaulted in DEBUG if unset)
DJANGO_ADMIN_USERNAME=admin
DJANGO_ADMIN_PASSWORD=admin
DJANGO_ADMIN_EMAIL=admin@robotcloud.local

# SMS Configuration (Volcengine)
# Leave empty in development to skip real SMS sending
VOLC_ACCESS_KEY_ID=
VOLC_SECRET_ACCESS_KEY=
VOLC_SMS_ACCOUNT=
VOLC_SMS_SIGN_NAME=
VOLC_SMS_TEMPLATE_ID=

# Alipay Configuration
# Leave empty in development to use mock payment
ALIPAY_APP_ID=
ALIPAY_PRIVATE_KEY=
ALIPAY_PUBLIC_KEY=
ALIPAY_GATEWAY=https://openapi.alipay.com/gateway.do
PLUS_PRICE_CENTS=100000
# Optional: set to 1 for a 0.01 RMB sandbox order while DJANGO_DEBUG=true.
PAYMENT_DEV_AMOUNT_CENTS=100000
