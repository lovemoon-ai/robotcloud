{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "RobotCloud",
  "version": "0.2.0",
  "identifier": "top.conductor-ai.robotcloud.desktop",
  "build": {
    "frontendDist": "placeholder"
  },
  "app": {
    "withGlobalTauri": true,
    "security": {
      "capabilities": ["desktop"]
    }
  },
  "bundle": {
    "active": true,
    "targets": ["msi"],
    "category": "DeveloperTool",
    "icon": ["icons/icon.png", "icons/icon.ico"],
    "resources": [
      "resources/scripts/robotcloud_auto_record.py",
      "resources/scripts/robotcloud_reset_pose.py",
      "resources/scripts/robotcloud_draw_circle.py",
      "resources/assets/so101_new_calib.urdf",
      "resources/runtime/*/lerobot-env-*.zip"
    ],
    "macOS": {
      "infoPlist": "Info.plist"
    },
    "windows": {
      "webviewInstallMode": {
        "type": "offlineInstaller",
        "silent": true
      },
      "wix": {
        "language": "en-US"
      }
    }
  }
}
